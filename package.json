{
  "name": "@swarmmachina/swm-uws",
  "version": "0.4.1",
  "description": "High-performance, drop-in non-TLS uWebSockets.js binding for Node.js 22 and 24",
  "upstream": {
    "uWebSocketsJs": "v20.69.0"
  },
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "LICENSES/",
    "lib/",
    "prebuilds/",
    "scripts/profile-http-raw-linux.sh",
    "scripts/profile-http-raw-load.js",
    "scripts/profile-http-raw-server.js",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "engines": {
    "node": "22.x || 24.x"
  },
  "scripts": {
    "bench:server": "node scripts/bench-server.js",
    "bench:report": "node scripts/generate-pgo-report.js",
    "bench:report:check": "node scripts/generate-pgo-report.js --check",
    "bench:compare:pgo:linux": "bash scripts/benchmark-pgo-compare-linux.sh",
    "bench:v8-http-server": "node scripts/bench-v8-http-server.js",
    "bench:ws": "node scripts/bench-ws.js",
    "profile:http-raw:linux": "bash scripts/profile-http-raw-linux.sh",
    "check": "prettier . --check && eslint .",
    "fix": "eslint . --fix && prettier . --write",
    "install": "node -e \"\"",
    "build:native": "node-gyp rebuild && node scripts/copy-prebuild.js",
    "build:native:pgo": "bash scripts/build-native-pgo.sh",
    "build:prebuilds": "npm run build:prebuilds:linux",
    "build:prebuilds:linux": "node scripts/build-linux-prebuilds.js",
    "deps:update:vendor": "node scripts/update-vendor.js",
    "deps:check:vendor": "node scripts/check-vendor.js",
    "check:release": "node scripts/check-release-prebuilds.js",
    "clean": "node-gyp clean",
    "prepublishOnly": "npm run check:release",
    "test": "node --test test/import-compatibility.test.js test/upstream-surface.test.js && node test/smoke.js",
    "test:compat:upstream": "node scripts/compare-upstream-surface.js",
    "test:v8-http": "node test/v8-http-smoke.js",
    "test:v8-ws": "node test/v8-ws-smoke.js"
  },
  "devDependencies": {
    "@swarmmachina/standards": "^1.1.2",
    "node-gyp": "^11.0.0",
    "prettier": "^3.9.5"
  }
}
